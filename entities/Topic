    },
    "order": {
      "type": "number",
      "description": "Orden de aparici\u00f3n"
    },
    "protocol_code": {
      "type": "string",
      "description": "C\u00f3digo del protocolo"
    },
    "protocol_edition": {
      "type": "string",
      "description": "Edici\u00f3n del protocolo"
